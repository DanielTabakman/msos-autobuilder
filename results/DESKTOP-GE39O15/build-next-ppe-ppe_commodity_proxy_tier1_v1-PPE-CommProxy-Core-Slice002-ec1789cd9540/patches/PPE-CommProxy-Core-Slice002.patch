+def _validate_commodity_proxy_labels(asset_id: str, catalog_asset: dict[str, Any] | None) -> tuple[bool, str]:
+    """Commodity proxy rows must be honest ETF-options labels, not futures copy."""
+    if asset_class(asset_id) != "commodity_proxy":
+        return True, "not commodity_proxy"
+
+    entry = get_asset(asset_id)
+    label = str((catalog_asset or {}).get("label") or entry.get("label") or "")
+    notes = [str(n) for n in (catalog_asset or {}).get("trust_notes") or []]
+    if "etf options" not in label.lower() and not any("etf options" in n.lower() for n in notes):
+        return False, "commodity proxy label must say ETF options"
+
+    text = " ".join([label, *notes]).lower()
+    forbidden = ("comex futures", "nymex futures", "cme futures")
+    if any(term in text for term in forbidden):
+        return False, "commodity proxy label must not claim futures venue"
+    return True, "commodity proxy ETF label ok"
+
