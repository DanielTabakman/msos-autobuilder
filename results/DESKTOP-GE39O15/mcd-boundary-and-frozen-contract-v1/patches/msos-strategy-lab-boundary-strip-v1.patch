index 00000000..f53af885
--- /dev/null
+++ b/apps/msos-web/tests/test_strategy_lab_explainer_strip.py
@@ -0,0 +1,25 @@
+"""Focused witness for the Strategy Lab demo explainer strip."""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+MSOS_WEB = Path(__file__).resolve().parents[1]
+
+
+def test_strategy_lab_header_explainer_strip_copy_and_styles() -> None:
+    shell = (MSOS_WEB / "src" / "components" / "StrategyLabClientShell.tsx").read_text(
+        encoding="utf-8"
+    )
+    css = (MSOS_WEB / "src" / "app" / "globals.css").read_text(encoding="utf-8")
+
+    assert "lab-explainer-strip" in shell
+    assert 'aria-label="What\'s happening here"' in shell
+    assert "MSOS turns your thesis into a paper-trade workflow." in shell
+    assert "PPE supplies the read-only" in shell
+    assert "options-implied distribution. No live orders." in shell
+    assert shell.index('className="title">Strategy Lab</h1>') < shell.index("lab-explainer-strip")
+    assert shell.index("lab-explainer-strip") < shell.index('mode === "demo"')
+
+    assert ".lab-explainer-strip" in css
+    assert ".lab-explainer-strip p" in css
