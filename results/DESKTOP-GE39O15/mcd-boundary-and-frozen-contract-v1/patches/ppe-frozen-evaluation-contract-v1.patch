diff --git a/src/viz/frozen_evaluation_contract.py b/src/viz/frozen_evaluation_contract.py
new file mode 100644
index 00000000..1cd8a91d
--- /dev/null
+++ b/src/viz/frozen_evaluation_contract.py
@@ -0,0 +1,173 @@
+"""Versioned Python-owned contracts for frozen evaluation snapshots."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+
+FROZEN_EVALUATION_SCHEMA_VERSION = "frozen_evaluation_v1"
+LEGACY_FROZEN_EVALUATION_SCHEMA_VERSION = "ppe_frozen_eval_v1"
+SUPPORTED_FROZEN_EVALUATION_SCHEMA_VERSIONS: tuple[str, ...] = (
+    FROZEN_EVALUATION_SCHEMA_VERSION,
+    LEGACY_FROZEN_EVALUATION_SCHEMA_VERSION,
+)
+
+SNAPSHOT_REVIEW_SCHEMA_VERSION = "snapshot_review_v1"
+SUPPORTED_SNAPSHOT_REVIEW_SCHEMA_VERSIONS: tuple[str, ...] = (SNAPSHOT_REVIEW_SCHEMA_VERSION,)
+
+FROZEN_EVALUATION_HEADER_FIELDS: tuple[str, ...] = (
+    "snapshot_id",
+    "created_at_utc",
+    "payload_schema_version",
+    "expiry",
+    "owner_email",
+    "classifier_version",
+    "benchmark_witness",
+    "data_quality",
+    "primary_output_state",
+    "classification_label",
+    "materiality_rule_version",
+    "market_width_1sigma_move_pct",
+    "benchmark_width_1sigma_move_pct",
+    "materiality_m_ratio",
+)
+
+FROZEN_EVALUATION_REQUIRED_FIELDS: tuple[str, ...] = (
+    "snapshot_id",
+    "created_at_utc",
+    "payload_schema_version",
+    "expiry",
+    "classifier_version",
+    "benchmark_witness",
+    "verification",
+)
+
+SNAPSHOT_REVIEW_REQUIRED_FIELDS: tuple[str, ...] = (
+    "payload_schema_version",
+    "snapshot_id",
+    "created_at",
+    "expiry",
+    "summary_line",
+    "record_header",
+    "review",
+)
+
+SNAPSHOT_REVIEW_ROW_FIELDS: tuple[str, ...] = (
+    "id",
+    "review_status",
+    "outcome_notes",
+    "reviewed_at_utc",
+    "review_horizon_ref",
+    "paper_tag",
+)
+
+
+class FrozenEvaluationContractError(ValueError):
+    """Raised when a frozen evaluation boundary payload violates the Python contract."""
+
+
+def _require_mapping(value: Any, *, label: str) -> dict[str, Any]:
+    if not isinstance(value, dict):
+        raise FrozenEvaluationContractError(f"{label} must be a JSON object")
+    return value
+
+
+def _require_fields(payload: dict[str, Any], required: tuple[str, ...], *, label: str) -> None:
+    missing = [field for field in required if field not in payload]
+    if missing:
+        raise FrozenEvaluationContractError(f"{label} missing required field(s): {', '.join(missing)}")
+
+
+def validate_frozen_evaluation_record(record: dict[str, Any]) -> dict[str, Any]:
+    """Validate the persisted frozen evaluation record shape at Python-owned boundaries."""
+    rec = _require_mapping(record, label="frozen evaluation record")
+    _require_fields(rec, FROZEN_EVALUATION_REQUIRED_FIELDS, label="frozen evaluation record")
+
+    version = str(rec.get("payload_schema_version") or "").strip()
+    if version not in SUPPORTED_FROZEN_EVALUATION_SCHEMA_VERSIONS:
+        raise FrozenEvaluationContractError(
+            "unsupported frozen evaluation payload_schema_version "
+            f"{version!r}; supported: {SUPPORTED_FROZEN_EVALUATION_SCHEMA_VERSIONS}"
+        )
+    _require_mapping(rec.get("benchmark_witness"), label="frozen evaluation benchmark_witness")
+    _require_mapping(rec.get("verification"), label="frozen evaluation verification")
+
+    for field in ("snapshot_id", "created_at_utc", "expiry", "classifier_version"):
+        if str(rec.get(field) or "").strip() == "":
+            raise FrozenEvaluationContractError(f"frozen evaluation record field {field!r} is required")
+    return rec
+
+
+def frozen_evaluation_header(record: dict[str, Any]) -> dict[str, Any]:
+    """Extract the deterministic review-facing header from a validated frozen record."""
+    rec = validate_frozen_evaluation_record(record)
+    return {field: rec.get(field) for field in FROZEN_EVALUATION_HEADER_FIELDS}
+
+
+def serialize_frozen_evaluation_record(record: dict[str, Any]) -> str:
+    """Validate and serialize a frozen record in stable compact JSON form."""
+    return json.dumps(
+        validate_frozen_evaluation_record(record),
+        separators=(",", ":"),
+        ensure_ascii=False,
+        sort_keys=True,
+    )
+
+
+def deserialize_frozen_evaluation_record(raw_json: str) -> dict[str, Any]:
+    """Deserialize and validate a persisted frozen record."""
+    try:
+        payload = json.loads(raw_json)
+    except json.JSONDecodeError as exc:
+        raise FrozenEvaluationContractError(f"invalid frozen evaluation JSON: {exc}") from exc
+    return validate_frozen_evaluation_record(payload)
+
+
+def build_snapshot_review_payload(
+    *,
+    snapshot_id: str,
+    created_at: str | None,
+    expiry: str | None,
+    summary_line: str | None,
+    record: dict[str, Any],
+    review: dict[str, Any] | None,
+) -> dict[str, Any]:
+    """Build the explicit review-facing payload for a frozen snapshot plus review row."""
+    review_doc = dict(review or {})
+    payload = {
+        "payload_schema_version": SNAPSHOT_REVIEW_SCHEMA_VERSION,
+        "snapshot_id": str(snapshot_id),
+        "created_at": created_at,
+        "expiry": expiry,
+        "summary_line": summary_line,
+        "record_header": frozen_evaluation_header(record),
+        "review": {
+            "id": review_doc.get("id"),
+            "review_status": review_doc.get("review_status"),
+            "outcome_notes": review_doc.get("outcome_notes"),
+            "reviewed_at_utc": review_doc.get("reviewed_at_utc"),
+            "review_horizon_ref": review_doc.get("review_horizon_ref"),
+            "paper_tag": review_doc.get("paper_tag"),
+        },
+    }
+    return validate_snapshot_review_payload(payload)
+
+
+def validate_snapshot_review_payload(payload: dict[str, Any]) -> dict[str, Any]:
+    """Validate the Python-owned snapshot review payload contract."""
+    doc = _require_mapping(payload, label="snapshot review payload")
+    _require_fields(doc, SNAPSHOT_REVIEW_REQUIRED_FIELDS, label="snapshot review payload")
+
+    version = str(doc.get("payload_schema_version") or "").strip()
+    if version not in SUPPORTED_SNAPSHOT_REVIEW_SCHEMA_VERSIONS:
+        raise FrozenEvaluationContractError(
+            "unsupported snapshot review payload_schema_version "
+            f"{version!r}; supported: {SUPPORTED_SNAPSHOT_REVIEW_SCHEMA_VERSIONS}"
+        )
+    header = _require_mapping(doc.get("record_header"), label="snapshot review record_header")
+    _require_fields(header, FROZEN_EVALUATION_HEADER_FIELDS, label="snapshot review record_header")
+    review = _require_mapping(doc.get("review"), label="snapshot review review")
+    _require_fields(review, SNAPSHOT_REVIEW_ROW_FIELDS, label="snapshot review review")
+    if str(doc.get("snapshot_id") or "").strip() == "":
+        raise FrozenEvaluationContractError("snapshot review payload field 'snapshot_id' is required")
+    return doc
