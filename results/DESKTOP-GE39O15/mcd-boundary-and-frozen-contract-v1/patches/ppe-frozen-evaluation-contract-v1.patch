diff --git a/tests/test_frozen_evaluation_contract.py b/tests/test_frozen_evaluation_contract.py
new file mode 100644
index 00000000..a828e1cc
--- /dev/null
+++ b/tests/test_frozen_evaluation_contract.py
@@ -0,0 +1,152 @@
+"""Versioned frozen evaluation and snapshot review contracts."""
+
+from __future__ import annotations
+
+import json
+import tempfile
+from pathlib import Path
+
+import pytest
+
+from src.viz.frozen_evaluation_contract import (
+    FROZEN_EVALUATION_SCHEMA_VERSION,
+    LEGACY_FROZEN_EVALUATION_SCHEMA_VERSION,
+    SNAPSHOT_REVIEW_SCHEMA_VERSION,
+    FrozenEvaluationContractError,
+    build_snapshot_review_payload,
+    deserialize_frozen_evaluation_record,
+    frozen_evaluation_header,
+    serialize_frozen_evaluation_record,
+    validate_frozen_evaluation_record,
+    validate_snapshot_review_payload,
+)
+from src.viz.frozen_evaluation_store import get_by_id, insert_record, open_store
+
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "frozen_evaluation"
+
+
+def _load_fixture(name: str) -> dict:
+    return json.loads((FIXTURE_DIR / name).read_text(encoding="utf-8"))
+
+
+def test_frozen_evaluation_v1_record_matches_golden_header() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+    review_payload = _load_fixture("snapshot_review_v1_payload.json")
+
+    assert validate_frozen_evaluation_record(record) == record
+    assert record["payload_schema_version"] == FROZEN_EVALUATION_SCHEMA_VERSION
+    assert frozen_evaluation_header(record) == review_payload["record_header"]
+    assert "verification" not in review_payload["record_header"]
+
+
+def test_snapshot_review_v1_payload_matches_golden() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+    expected = _load_fixture("snapshot_review_v1_payload.json")
+
+    payload = build_snapshot_review_payload(
+        snapshot_id=record["snapshot_id"],
+        created_at=record["created_at_utc"],
+        expiry=record["expiry"],
+        summary_line=expected["summary_line"],
+        record=record,
+        review=expected["review"],
+    )
+
+    assert payload["payload_schema_version"] == SNAPSHOT_REVIEW_SCHEMA_VERSION
+    assert payload == expected
+    assert validate_snapshot_review_payload(payload) == expected
+
+
+def test_frozen_evaluation_required_fields_and_unsupported_versions() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+
+    missing_version = dict(record)
+    missing_version.pop("payload_schema_version")
+    with pytest.raises(FrozenEvaluationContractError, match="missing required field.*payload_schema_version"):
+        validate_frozen_evaluation_record(missing_version)
+
+    unsupported = dict(record, payload_schema_version="frozen_evaluation_v2")
+    with pytest.raises(FrozenEvaluationContractError, match="unsupported frozen evaluation payload_schema_version"):
+        validate_frozen_evaluation_record(unsupported)
+
+
+def test_snapshot_review_required_fields_and_unsupported_versions() -> None:
+    payload = _load_fixture("snapshot_review_v1_payload.json")
+
+    missing_review = dict(payload)
+    missing_review.pop("review")
+    with pytest.raises(FrozenEvaluationContractError, match="missing required field.*review"):
+        validate_snapshot_review_payload(missing_review)
+
+    unsupported = dict(payload, payload_schema_version="snapshot_review_v2")
+    with pytest.raises(FrozenEvaluationContractError, match="unsupported snapshot review payload_schema_version"):
+        validate_snapshot_review_payload(unsupported)
+
+
+def test_frozen_evaluation_serialization_round_trip_is_stable() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+
+    raw = serialize_frozen_evaluation_record(record)
+    round_tripped = deserialize_frozen_evaluation_record(raw)
+
+    assert round_tripped == record
+    assert serialize_frozen_evaluation_record(round_tripped) == raw
+
+
+def test_legacy_frozen_eval_schema_version_is_read_compatible() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+    legacy = dict(record, payload_schema_version=LEGACY_FROZEN_EVALUATION_SCHEMA_VERSION)
+
+    assert deserialize_frozen_evaluation_record(json.dumps(legacy))["payload_schema_version"] == (
+        LEGACY_FROZEN_EVALUATION_SCHEMA_VERSION
+    )
+
+
+def test_store_boundary_rejects_unsupported_frozen_versions() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+
+    with tempfile.TemporaryDirectory() as td:
+        conn = open_store(Path(td) / "contract.sqlite")
+        try:
+            bad = dict(record, snapshot_id="bad-version", payload_schema_version="frozen_evaluation_v2")
+            with pytest.raises(FrozenEvaluationContractError):
+                insert_record(conn, bad)
+
+            conn.execute(
+                """
+                INSERT INTO frozen_evaluations
+                (id, created_at, expiry, summary_line, record_json, owner_email)
+                VALUES (?, ?, ?, ?, ?, ?)
+                """,
+                (
+                    "bad-persisted",
+                    record["created_at_utc"],
+                    record["expiry"],
+                    "bad persisted",
+                    json.dumps(bad),
+                    None,
+                ),
+            )
+            conn.commit()
+            with pytest.raises(FrozenEvaluationContractError):
+                get_by_id(conn, "bad-persisted")
+        finally:
+            conn.close()
+
+
+def test_store_round_trip_keeps_contract_payload_stable() -> None:
+    record = _load_fixture("frozen_evaluation_v1_record.json")
+
+    with tempfile.TemporaryDirectory() as td:
+        conn = open_store(Path(td) / "stable.sqlite")
+        try:
+            rid = insert_record(conn, record)
+            assert rid == record["snapshot_id"]
+            assert get_by_id(conn, rid) == record
+            stored = conn.execute(
+                "SELECT record_json FROM frozen_evaluations WHERE id = ?", (rid,)
+            ).fetchone()["record_json"]
+            assert stored == serialize_frozen_evaluation_record(record)
+        finally:
+            conn.close()
